	month = oct,
	year = {2010},
	n = {TLDR: The results suggest that the structure of goal-directed behavior may be represented abstractly, independently of specific actions and goals, just as linguistic syntax is thought to stand independent of other levels of representation.},
	pages = {1518--1524},
	file = {PDF:/Users/zhihaowang/Zotero/storage/CX7K7FJW/Allen et al. - 2010 - Abstract Structural Representations of Goal-Directed Behavior.pdf:application/pdf},
