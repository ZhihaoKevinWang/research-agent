	d = {10.1016/j.obhdp.2021.104113},
	abstract = {When firms or individuals stand to benefit from dng good, observers often question their motivations and discount their good deeds. We propose that this attribution process is sensitive not only to the presence of extrinsic incentives, but also to their prior likelihoods. Across eleven studies, observers treat uncertain rewards (vs. equally valuable certain rewards) as weaker signals of extrinsic motivation. Consequently, observers judge actors who do good when facing uncertain incentives as more purely motivated, benevolent, and likable, and they prefer products from brands that incur profit uncertainty when launching CSR initiatives. Even actors who are handsomely rewarded for dng good are judged favorably if rewards were uncertain at the outset. These effects may stem from more general processes of counterfactual attribution: Actors who do good knowing they might not be rewarded for it may seem more like they would have been willing to act without any incentive at all.},
	language = {en},
	udate = {2025-08-13},
	journal = {Organizational Behavior and Human Decision Processes},
	author = {Silver, Ike and Silverman, Jackie},
	month = jan,
	year = {2022},
	n = {TLDR: “observers treat uncertain rewards (vs. equally valuable certain rewards) as weaker signals of extrinsic motivation. Even if they were awarded later, this effect mediated by Motive Purity. No effect if the uncertain goal is desired.},
	keywords = {⭐},
	pages = {104113},
	file = {PDF:/Users/zhihaowang/Zotero/storage/294N92PQ/Silver and Silverman - 2022 - dng good for (maybe) nothing How reward uncertainty shapes observer responses to prosocial behavi.pdf:application/pdf},
}

