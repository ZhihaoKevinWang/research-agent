	volume = {92},
	issn = {1939-1315, 0022-3514},
	shorttitle = {The dilution model},
	u = {https://d.apa.org/d/10.1037/0022-3514.92.3.389},
	d = {10.1037/0022-3514.92.3.389},
	abstract = {Six experiments tested a dilution model of self-regulation, whereby increasing the number of goals (e.g., building muscles and losing weight) that a single means (e.g., exercising) can satisfy reduces the perception of its instrumentality with respect to each goal. The authors found that an increase in the number of simultaneous, salient goals that can be satisfied via a single means weakens the associative strength between that means and each individual goal, and as a result, individuals perceive the means as less effective for the attainment of each goal. Consequently, means that are connected to multiple (vs. single) goals are less likely to be chosen and pursued when only one of these goals is activated.},
	language = {en},
	number = {3},
	udate = {2025-08-14},
	journal = {Journal of Personality and Social Psychology},
	author = {Zhang, Ying and Fishbach, Ayelet and Kruglanski, Arie W.},
	year = {2007},
	n = {TLDR: an increase in the number of simultaneous, salient goals that can be satisfied via a single means weakens the associative strength between that means and each individual goal, and as a result, individuals perceive the means as less effective for the attainment of each goal. This effect is mediated by Means-goal associative strength.},
	pages = {389--401},
	file = {PDF:/Users/zhihaowang/Zotero/storage/PWQZLCEW/Zhang et al. - 2007 - The dilution model How additional goals undermine the perceived instrumentality of a shared path..pdf:application/pdf},
}
